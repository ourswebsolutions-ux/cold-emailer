generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                String         @id @default(cuid())
  phone             String         @unique
  passwordHash      String
  name              String?
  role              UserRole       @default(USER)
  status            UserStatus     @default(DISABLED)
  passwordExpiresAt DateTime
  sessionExpiresAt  DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  smtpConfigs       SMTPConfig[]
    emails            Email[]
  systemConfig      SystemConfig[]
  emailTemplates EmailTemplate[]
}

model SMTPConfig {
  id          String   @id @default(cuid())
  userId      String
  host        String
  port        Int
  username    String
  password    String
  senderEmail String
  senderName  String?
  isActive    Boolean  @default(false)
  warmup      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, senderEmail])
}

model SystemConfig {
  id          String   @id @default(cuid())
  userId      String
  host        String
  port        Int
  username    String
  password    String
  senderEmail String
  senderName  String?
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, senderEmail])
}

model WarmupEmail {
  id String @id @default(cuid())

  senderId String
  receiverEmail String

  subject String
  status String

  sentAt DateTime @default(now())

  createdAt DateTime @default(now())
}

enum UserRole {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  DISABLED
}


model EmailTemplate {
  id        String   @id @default(cuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  subject   String
  body String? @db.LongText

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}


model Email {
  id          String   @id @default(cuid())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  
  name        String?

  email       String

  company     String?
  website     String?
  phone       String?

  category    String?

  status      EmailStatus @default(PENDING)

  isVerified  Boolean @default(false)
  isValid     Boolean?

  notes       String? @db.Text

  customFields Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  
  @@index([userId])
  
  @@index([email])
  @@index([category])
}


enum EmailStatus {
  PENDING
  VALID
  INVALID
  SENT
  FAILED
  BOUNCED
  REPLIED
  UNSUBSCRIBED
}